# Copy to .env and fill in. Never commit .env.
# ----------------------------------------------------------------------

# --- LLM (dev tier for probes/ablations, Days 1-4) ---
OPENROUTER_API_KEY=
DEV_MODEL=qwen/qwen3-next-80b-a3b
# Alternative: deepseek/deepseek-v3.2

# --- LLM (eval tier, sealed held-out only, Days 5-7) ---
ANTHROPIC_API_KEY=
EVAL_MODEL=claude-sonnet-4-6

# --- Email (PRIMARY channel) ---
# Resend free tier — 3,000 emails/month, no credit card required.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
STAFF_SINK_EMAIL=

# --- SMS (SECONDARY channel, warm-lead scheduling only) ---
AT_USERNAME=sandbox
AT_API_KEY=
AT_SHORTCODE=
AT_WEBHOOK_URL=
STAFF_SINK_NUMBER=

# --- HubSpot (CRM) ---
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PORTAL_ID=

# --- Cal.com (self-hosted) ---
CALCOM_BASE_URL=http://localhost:3000
CALCOM_API_KEY=
CALCOM_EVENT_TYPE_ID=

# --- Observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Kill switch ---
# If unset or not "1", all outbound email and SMS is routed to the staff sink.
# Default MUST be unset per data-handling policy.
LIVE_OUTBOUND=

# --- Runtime ---
ENV=dev
LOG_LEVEL=INFO
PORT=8080
