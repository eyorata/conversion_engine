# Copy to `.env` and fill in real values. Never commit your populated `.env`.

# --- LLM (dev tier; probes, synthetic runs, local iteration) ---
# OpenRouter API key used by the dev-tier orchestrator.
OPENROUTER_API_KEY=
# Default dev model for Days 1-4 and most local testing.
DEV_MODEL=qwen/qwen3-next-80b-a3b-instruct

# --- LLM (eval tier; sealed held-out only) ---
ANTHROPIC_API_KEY=
EVAL_MODEL=claude-sonnet-4-6

# --- Email (primary channel via Resend) ---
# Resend API key with permission to send mail.
RESEND_API_KEY=
# Sender identity. For dev you can use onboarding@resend.dev; for reliable
# reply handling, use a verified sender/domain.
RESEND_FROM_EMAIL=
# Sink inbox used whenever LIVE_OUTBOUND is unset / false.
STAFF_SINK_EMAIL=

# --- SMS (secondary channel via Africa's Talking) ---
# "sandbox" keeps requests on the AT sandbox host.
AT_USERNAME=sandbox
AT_API_KEY=
# Optional sender short code / sender id.
AT_SHORTCODE=
# Public callback URL registered with Africa's Talking for inbound SMS.
AT_WEBHOOK_URL=
# Sink number used whenever LIVE_OUTBOUND is unset / false.
STAFF_SINK_NUMBER=

# --- HubSpot CRM ---
# Backend mode: `rest` works today, `mcp` expects a configured HubSpot MCP server.
HUBSPOT_MODE=rest
# Developer sandbox private-app token.
HUBSPOT_ACCESS_TOKEN=
# Optional portal/account id for screenshots or debugging.
HUBSPOT_PORTAL_ID=
# Optional MCP server command and args if using HUBSPOT_MODE=mcp.
HUBSPOT_MCP_COMMAND=
HUBSPOT_MCP_ARGS=
# Tool names exposed by your MCP server.
HUBSPOT_MCP_UPSERT_TOOL=hubspot_upsert_contact
HUBSPOT_MCP_NOTE_TOOL=hubspot_log_note

# --- Cal.com ---
# Local self-hosted Cal.com default.
CALCOM_BASE_URL=http://localhost:3000
CALCOM_API_KEY=
# Event type id used for slot lookup and booking creation.
CALCOM_EVENT_TYPE_ID=
# Optional shared secret checked by the /calcom/webhook route.
CALCOM_WEBHOOK_SECRET=

# --- Observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Kill switch ---
# If unset or not "1", all outbound email and SMS are routed to sink values.
LIVE_OUTBOUND=

# --- Runtime ---
ENV=dev
LOG_LEVEL=INFO
PORT=8080
